# Google Forms Configuration
# Para obtener la URL de tu formulario:
# 1. Crea tu formulario en https://docs.google.com/forms/
# 2. Click en "Enviar" (botón superior derecho)
# 3. Selecciona la pestaña "<>" (Insertar HTML)
# 4. Copia el valor del atributo "src" del iframe
# 5. Pégalo aquí como valor de VITE_GOOGLE_FORM_URL

VITE_GOOGLE_FORM_URL=https://docs.google.com/forms/d/e/TU_FORM_ID/viewform?embedded=true
